<script>
  // Fonction pour insérer une adresse email dans un conteneur donné
  function insertEmail(containerId, email, label) {
    var container = document.getElementById(containerId);
    if (!container) return;

    // Supprime le contenu existant (ex: texte de dégradation)
    container.textContent = "";

    // Crée le lien mailto
    var emailLink = document.createElement("a");
    emailLink.href = "mailto:" + email;
    emailLink.style.color = "#103653";
    emailLink.style.textDecoration = "none";
    emailLink.setAttribute("aria-label", label); // Pour lecteurs d'écran

    // Crée et ajoute le texte visible du mail
    var emailText = document.createTextNode(email);
    emailLink.appendChild(emailText);

    // Ajoute le lien dans le conteneur
    container.appendChild(emailLink);
  }

  // Adresse email à afficher
  var email = "chubert.assmat91@yahoo.com";

  // Insère l'email dans les deux conteneurs
  insertEmail("emailContainer2", email, "Envoyer un email à Céline Hubert");
  insertEmail("emailContainerPolitique", email, "Envoyer un email à Céline Hubert");
</script>
